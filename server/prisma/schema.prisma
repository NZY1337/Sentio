generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

enum Role {
    admin
    user
    editor
}

enum SpaceType {
    LIVING_ROOM
    BEDROOM
    KITCHEN
    BATHROOM
    DINING_ROOM
    HOME_OFFICE
    KIDS_ROOM
    HALLWAY_CORRIDOR
    BALCONY_TERRACE
    GAME_ROOM
    STUDY
}

enum Category {
    DESIGN_GENERATOR
    DESIGN_EDITOR
}

enum DesignTheme {
    MODERN
    CONTEMPORARY
    MINIMALIST
    SCANDINAVIAN
    INDUSTRIAL
    MID_CENTURY_MODERN
    TRADITIONAL
    CLASSIC
    BAROQUE
    JAPANESE_ZEN
    WABI_SABI
    FARMHOUSE
    RUSTIC
    BOHEMIAN
    ART_DECO
    VICTORIAN
    COASTAL
    TROPICAL
    URBAN
    MAXIMALIST
    FUTURISTIC
}

enum OutputFormat {
    PNG
    JPEG
    WEBP
}

enum QualityFormat {
    HIGH
    MEDIUM
    LOW
}

enum SizeImage {
    SIZE_1024x1024
    SIZE_1024x1536
    SIZE_1536x1024
    AUTO
}

model User {
    id          String   @id
    username    String
    email       String   @unique
    role        Role     @default(user)
    consent      Boolean  @default(false)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    journals  JournalEntry[]
    alerts    Alert[]
}


model JournalEntry {
  id         String    @id @default(uuid())
  userId     String
  content    String
  createdAt  DateTime  @default(now())
  embedding  Float[]  

  user       User   @relation(fields: [userId], references: [id])
  analysis   EmotionalAnalysis?
}

model EmotionalAnalysis {
  id                  String   @id @default(uuid())
  journalEntryId      String   @unique
  dominantEmotion     String
  cognitiveDistortion String?
  riskScore           Int?

  journalEntry        JournalEntry @relation(fields: [journalEntryId], references: [id])
}

model Alert {
  id        String   @id @default(uuid())
  userId String
  message   String
  level     String   // ex: info, warning, critical
  createdAt DateTime @default(now())

  user   User @relation(fields: [userId], references: [id])
}
