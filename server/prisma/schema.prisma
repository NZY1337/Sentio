generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

enum Role {
    admin
    user
    editor
}

model User {
    id          String   @id
    username    String
    consent     Boolean  @default(false) 
    email       String   @unique
    role        Role     @default(user)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
}